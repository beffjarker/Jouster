# =============================================================================
# Jouster Environment Configuration Template
# =============================================================================
# NEVER commit real credentials to git!
# Copy this file to .env and fill in your actual values
#
# Environment Files:
#   .env              - Local development (this file after copying)
#   .env.qa           - QA/Preview environment
#   .env.staging      - Staging environment
#   .env.production   - Production environment
# =============================================================================

# =============================================================================
# Environment Configuration
# =============================================================================
NODE_ENV=development
PORT=3000

# =============================================================================
# AWS Configuration
# =============================================================================
# IAM User: jouster-dev (for local development)
# Get credentials from AWS Console → IAM → Users → jouster-dev → Security credentials
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-west-2

# Admin credentials (ONLY for infrastructure setup - DO NOT USE IN APPLICATION)
# IAM User: jouster-admin
AWS_ADMIN_ACCESS_KEY_ID=your_admin_access_key_here
AWS_ADMIN_SECRET_ACCESS_KEY=your_admin_secret_key_here
AWS_ADMIN_REGION=us-west-2

# =============================================================================
# DynamoDB Configuration
# =============================================================================
# Local: Use localhost endpoint for DynamoDB Local
# QA/Staging/Prod: Remove DYNAMODB_ENDPOINT to use AWS DynamoDB service
DYNAMODB_ENDPOINT=http://localhost:8000
DYNAMODB_REGION=us-west-2

# =============================================================================
# S3 Configuration
# =============================================================================
# Environment-specific bucket names:
#   Local/Dev:  jouster-dev-bucket
#   QA:         jouster-qa-bucket
#   Staging:    jouster-staging-bucket
#   Production: jouster-prod-bucket
S3_BUCKET_NAME=jouster-dev-bucket
S3_REGION=us-west-2
S3_EMAIL_PREFIX=email/

# =============================================================================
# Instagram Graph API Configuration
# =============================================================================
# Setup: https://developers.facebook.com/
# Required: Business Instagram account connected to Facebook Page
INSTAGRAM_APP_ID=your_facebook_app_id
INSTAGRAM_APP_SECRET=your_facebook_app_secret
INSTAGRAM_ACCESS_TOKEN=your_page_access_token
INSTAGRAM_USER_ID=your_instagram_business_account_id

# =============================================================================
# Facebook Page Configuration
# =============================================================================
# Required for Instagram Graph API
FACEBOOK_PAGE_ID=your_facebook_page_id
FACEBOOK_PAGE_ACCESS_TOKEN=your_page_access_token

# =============================================================================
# Last.fm API Configuration
# =============================================================================
# Get API key: https://www.last.fm/api/account/create
LASTFM_API_KEY=your_lastfm_api_key
LASTFM_SHARED_SECRET=your_lastfm_shared_secret
LASTFM_USER=your_lastfm_username
# Session cookie for scrobble deletion (browser login → DevTools → Application → Cookies → sessionid)
LASTFM_SESSION_COOKIE=your_lastfm_session_cookie

# =============================================================================
# Session & Authentication
# =============================================================================
# Express session secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=your_session_secret_here
# Life Map password (plain text for login) and bcrypt hash (for verification)
# Generate hash: node apps/backend/scripts/generate-password-hash.js
LIFE_MAP_PASSWORD=your_life_map_password
LIFE_MAP_PASSWORD_HASH=$2b$10$your_bcrypt_hash_here
# DynamoDB table name for life-map entries
LIFE_MAP_TABLE_NAME=jouster-life-map-dev

# =============================================================================
# Personal AWS (separate IAM user for personal S3/DynamoDB resources)
# =============================================================================
# Optional: Only needed for personal life-map data in a separate AWS account
PERSONAL_AWS_ACCESS_KEY_ID=your_personal_access_key
PERSONAL_AWS_SECRET_ACCESS_KEY=your_personal_secret_key
PERSONAL_S3_BUCKET=your_personal_s3_bucket
PERSONAL_S3_REGION=us-west-2
PERSONAL_DYNAMODB_TABLE=your_personal_dynamodb_table

# =============================================================================
# GitHub Configuration (for CI/CD and dev-tools sync)
# =============================================================================
# Required for dev-tools/dev-journal git sync
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_USERNAME=your_github_username
GITHUB_REPOSITORY=owner/repo-name

# =============================================================================
# Monitoring & Logging (Optional)
# =============================================================================
# Sentry for error tracking
SENTRY_DSN=your_sentry_dsn_here

# LogRocket for session replay
LOGROCKET_APP_ID=your_logrocket_app_id

# =============================================================================
# Feature Flags (Optional)
# =============================================================================
ENABLE_ANALYTICS=true
ENABLE_DEBUG_LOGGING=true
ENABLE_PERFORMANCE_MONITORING=false

# =============================================================================
# SETUP INSTRUCTIONS
# =============================================================================
# 1. Copy this file:
#    cp .env.example .env
#
# 2. Fill in your credentials (see comments above for where to get them)
#
# 3. NEVER commit .env to git (it's already in .gitignore)
#
# 4. For each environment (qa, staging, production):
#    - Create separate .env.{environment} file
#    - Use environment-specific IAM users and resources
#    - Document any environment-specific variables
#
# 5. Validate your setup:
#    npm run env:validate
# =============================================================================
