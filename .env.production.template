# Environment Variables Template for Production
# Copy this file and fill in real values
# NEVER commit the filled version to git

# ======================
# CRITICAL: Encryption
# ======================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_MASTER_KEY=

# ======================
# Environment
# ======================
NODE_ENV=production
PORT=3000
ENFORCE_HTTPS=true

# ======================
# AWS Credentials (Encrypted)
# ======================
# Use the credential-manager-secure.js to encrypt these
AWS_ACCESS_KEY_ID_ENCRYPTED=
AWS_SECRET_ACCESS_KEY_ENCRYPTED=
AWS_REGION=us-west-2

# AWS S3 Configuration
S3_BUCKET_NAME=
S3_EMAIL_PREFIX=email/

# ======================
# Instagram Graph API (Encrypted)
# ======================
INSTAGRAM_APP_ID_ENCRYPTED=
INSTAGRAM_APP_SECRET_ENCRYPTED=
INSTAGRAM_ACCESS_TOKEN_ENCRYPTED=
INSTAGRAM_USER_ID_ENCRYPTED=

# ======================
# Facebook Page (Encrypted)
# ======================
FACEBOOK_PAGE_ID_ENCRYPTED=
FACEBOOK_PAGE_ACCESS_TOKEN_ENCRYPTED=

# ======================
# Last.fm API (Encrypted)
# ======================
LASTFM_API_KEY_ENCRYPTED=
LASTFM_SHARED_SECRET_ENCRYPTED=
LASTFM_USER=Treysin

# ======================
# DynamoDB Configuration
# ======================
DYNAMODB_ENDPOINT=
DYNAMODB_REGION=us-west-2

# ======================
# Life Map (Production)
# ======================
# Production uses its own table with the real entries (separate from non-prod).
LIFE_MAP_TABLE_NAME=jouster-life-map-prod

# ======================
# Auth + Session (single-user hidden login)
# ======================
# bcrypt hash of the login password — generate with:
#   node apps/backend/scripts/generate-password-hash.js
LIFE_MAP_PASSWORD_HASH=
# Session signing secret — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=
# Persistent session store for production (requires the sessions table to exist)
SESSION_STORE=dynamodb
SESSION_TABLE_NAME=jouster-sessions

# ======================
# Production URLs
# ======================
DOMAIN=jouster.org
PRODUCTION_URL=https://jouster.org
API_BASE_URL=https://api.jouster.org

