# Environment Configuration Template for QA/Preview
# Copy to .env.qa and fill in QA-specific credentials

NODE_ENV=qa
PORT=3000

# AWS Configuration - QA Environment
# IAM User: jouster-qa
AWS_ACCESS_KEY_ID=your_qa_access_key_here
AWS_SECRET_ACCESS_KEY=your_qa_secret_key_here
AWS_REGION=us-west-2

# DynamoDB - QA (AWS Service, not local)
# Remove DYNAMODB_ENDPOINT to use AWS DynamoDB
# DYNAMODB_ENDPOINT=
DYNAMODB_REGION=us-west-2

# Life Map — shared NON-PROD table (dev/qa/staging all use this; fake literary data)
LIFE_MAP_TABLE_NAME=jouster-life-map-nonprod

# S3 - QA Environment
S3_BUCKET_NAME=jouster-qa-bucket
S3_REGION=us-west-2
S3_EMAIL_PREFIX=email/

# Instagram - Test Account
INSTAGRAM_APP_ID=your_qa_facebook_app_id
INSTAGRAM_APP_SECRET=your_qa_facebook_app_secret
INSTAGRAM_ACCESS_TOKEN=your_qa_page_access_token
INSTAGRAM_USER_ID=your_qa_instagram_business_account_id

# Facebook - Test Page
FACEBOOK_PAGE_ID=your_qa_facebook_page_id
FACEBOOK_PAGE_ACCESS_TOKEN=your_qa_page_access_token

# Last.fm - Test Account
LASTFM_API_KEY=your_qa_lastfm_api_key
LASTFM_SHARED_SECRET=your_qa_lastfm_shared_secret
LASTFM_USER=your_qa_lastfm_username

# Feature Flags for QA
ENABLE_ANALYTICS=true
ENABLE_DEBUG_LOGGING=true
ENABLE_PERFORMANCE_MONITORING=true

