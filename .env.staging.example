# Environment Configuration Template for Staging
# Copy to .env.staging and fill in staging-specific credentials

NODE_ENV=staging
PORT=3000

# AWS Configuration - Staging Environment
# IAM User: jouster-staging
AWS_ACCESS_KEY_ID=your_staging_access_key_here
AWS_SECRET_ACCESS_KEY=your_staging_secret_key_here
AWS_REGION=us-west-2

# DynamoDB - Staging (AWS Service)
DYNAMODB_REGION=us-west-2

# Life Map — shared NON-PROD table (dev/qa/staging all use this; fake literary data)
LIFE_MAP_TABLE_NAME=jouster-life-map-nonprod

# S3 - Staging Environment
S3_BUCKET_NAME=jouster-staging-bucket
S3_REGION=us-west-2
S3_EMAIL_PREFIX=email/

# Instagram - Pre-production Account
INSTAGRAM_APP_ID=your_staging_facebook_app_id
INSTAGRAM_APP_SECRET=your_staging_facebook_app_secret
INSTAGRAM_ACCESS_TOKEN=your_staging_page_access_token
INSTAGRAM_USER_ID=your_staging_instagram_business_account_id

# Facebook - Pre-production Page
FACEBOOK_PAGE_ID=your_staging_facebook_page_id
FACEBOOK_PAGE_ACCESS_TOKEN=your_staging_page_access_token

# Last.fm - Pre-production Account
LASTFM_API_KEY=your_staging_lastfm_api_key
LASTFM_SHARED_SECRET=your_staging_lastfm_shared_secret
LASTFM_USER=your_staging_lastfm_username

# Monitoring - Staging
SENTRY_DSN=your_staging_sentry_dsn

# Feature Flags for Staging (production-like)
ENABLE_ANALYTICS=true
ENABLE_DEBUG_LOGGING=false
ENABLE_PERFORMANCE_MONITORING=true

